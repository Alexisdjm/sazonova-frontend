# Variables para build de producción (Docker o npm run build).
# Copia y ajusta antes de desplegar:
#   cp .env.production.example .env.production
#
# En Docker: exporta las mismas variables en .env o pásalas en docker compose build.

REACT_APP_API_URL=https://api.mysazonova.com
REACT_APP_MAPBOX_ACCESS_TOKEN=
REACT_APP_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
REACT_APP_SITE_URL=https://mysazonova.com
GENERATE_SOURCEMAP=false
