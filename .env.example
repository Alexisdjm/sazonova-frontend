# Copia este archivo a .env para desarrollo local:
#   cp .env.example .env
#
# En Docker, las mismas variables se usan en build (ver docker-compose.yml).
# Create React App solo expone variables con prefijo REACT_APP_.

# API backend (Django u otro)
REACT_APP_API_URL=http://127.0.0.1:8000

# Mapbox (obligatorio para ver el mapa — reinicia npm start tras cambiar .env)
REACT_APP_MAPBOX_ACCESS_TOKEN=tu_token_de_mapbox
REACT_APP_MAPBOX_STYLE=mapbox://styles/julimendoza14/cmntsuojg002l01s32vub2sw1

# URL pública del sitio (opcional, para SEO/redes al desplegar)
# REACT_APP_SITE_URL=https://tudominio.com

# Build de producción (opcional)
GENERATE_SOURCEMAP=false

# Puerto del contenedor nginx (solo docker-compose, no afecta CRA)
WEB_PORT=80
