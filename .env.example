# Copia a .env para desarrollo local:
#   cp .env.example .env
#
# Create React App solo expone variables con prefijo REACT_APP_.
# Tras cambiar .env: reinicia npm start (dev) o vuelve a hacer build (prod).

# --- Desarrollo (backend Django en tu máquina) ---
REACT_APP_API_URL=http://127.0.0.1:8000

# --- Producción (obligatorio en el build; NO uses localhost) ---
# REACT_APP_API_URL=https://api.tudominio.com
#
# Si nginx en el mismo dominio hace proxy de /api al backend, puedes dejar vacío
# y usar rutas relativas (el build usará /api/...):
# REACT_APP_API_URL=

REACT_APP_MAPBOX_ACCESS_TOKEN=tu_token_de_mapbox
REACT_APP_MAPBOX_STYLE=mapbox://styles/julimendoza14/cmntsuojg002l01s32vub2sw1

# URL pública del sitio (opcional, SEO)
# REACT_APP_SITE_URL=https://tudominio.com

GENERATE_SOURCEMAP=false

# Solo docker-compose (puerto del contenedor web)
WEB_PORT=80
